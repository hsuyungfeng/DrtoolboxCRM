# Backend Environment Variables Example

# Application
NODE_ENV=development
PORT=3000

# Database
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=doctor_crm
DB_SSL=false

# Security
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# API Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
